# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# LLM Gateway (OpenRouter — https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# Voice (ElevenLabs — https://elevenlabs.io)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=           # Your cloned voice ID from ElevenLabs dashboard → Voices

# Booking — Google Calendar or any scheduling link
# Shown when recruiter asks sensitive questions (salary, etc.)
BOOKING_URL=https://calendar.app.google/...

# LangSmith — LLM observability (https://smith.langchain.com)
# Traces every AI conversation — useful for debugging and showcasing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fernando-ott-resume
LANGCHAIN_TRACING_V2=true

# Supabase — server-side only (BFF pattern, never sent to browser)
# All DB access goes through Next.js API routes
# Project setup: https://supabase.com → run supabase/migrations/001_init.sql
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# PostHog — recruiter behavior analytics (https://posthog.com, free tier)
# Tracks: questions asked, voice skip rate, exit-intent conversions, bookings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional: Slack webhook for new lead notifications
LEAD_NOTIFICATION_WEBHOOK=https://hooks.slack.com/...

# Resume page — private contacts (server-side only, not in public repo)
RESUME_EMAIL=you@example.com
RESUME_WHATSAPP=5541999190000   # digits only, no + or spaces
